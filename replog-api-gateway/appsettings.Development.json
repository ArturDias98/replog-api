{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth-host",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "sync": {
        "ClusterId": "sync-host",
        "Match": {
          "Path": "/api/sync/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-host": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5140/"
          }
        }
      },
      "sync-host": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5139/"
          }
        }
      }
    }
  }
}
